# ========== Node.js / Frontend ==========
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/.cache/

# ========== Rust / Backend ==========
# Папка сборки (ОЧЕНЬ ВАЖНО - она огромная!)
/target/
backend/rust-inference/target/
**/target/

# Файлы компиляции
*.rs.bk
*.pdb
*.exe
*.exe.pdb
*.dSYM/
*.rlib
*.dylib
*.so
*.dll

# Cargo lock (опционально - можно оставить, но обычно добавляют)
# /Cargo.lock
# backend/rust-inference/Cargo.lock

# ========== Go / Backend ==========
# Бинарные файлы
*.exe
*.exe~
*.dll
*.so
*.dylib
backend/go-collector/titan-collector
backend/go-collector/titan-collector.exe

# Зависимости
vendor/

# Файлы тестов
*.test
*.out

